---
import path from "node:path";
import type { ImageMetadata } from "astro";

interface Props {
  imagesGlob: Record<string, ImageMetadata>;
  imagesMeta: {
    file: string;
    caption?: string;
  }[];
}

const { imagesGlob, imagesMeta } = Astro.props;

// Dateiname -> Metadaten
const meta = new Map(
  imagesMeta.map((img) => [img.file, img])
);

const gallery = Object.entries(imagesGlob)
  .sort(([a], [b]) =>
    path.basename(a).localeCompare(path.basename(b), undefined, {
      numeric: true,
    })
  )
  .map(([file, src]) => {
    const name = path.basename(file);
    const info = meta.get(name);

    return {
      src,
      alt: info?.caption ?? "",
      caption: info?.caption,
    };
  });
---

<div class="gallery">
  {gallery.map(({ src, alt, caption }) => (
    <figure>
      <img src={src.src} alt={alt} loading="lazy" />
      {caption && <figcaption>{caption}</figcaption>}
    </figure>
  ))}
</div>