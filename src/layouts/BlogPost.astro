---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import type { ImageMetadata } from 'astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import Images from '../components/Images.astro';
import Distance from '../assets/icons/distance.svg';
import Start from '../assets/icons/start.svg';
import End from '../assets/icons/finish.svg';
import Gpx from '../assets/icons/gpx.svg';
import Date from '../assets/icons/date.svg';
import Walk from '../assets/icons/walk.svg';
import Bike from '../assets/icons/bike.svg';

type Props = CollectionEntry<'trips'>;

const { id, data } = Astro.props;

const {
  title,
  description,
  pubDate,
  distance,
  start,
  end,
  gpx,
  heroImage,
  heroImageAlt,
  images,
  category,
} = data;

let CategoryIcon = null;

switch (category) {
  case 'cycling':
    CategoryIcon = Bike;
    break;
  case 'hiking':
    CategoryIcon = Walk;
    break;
}

// Alle Bilder laden
const allImages = import.meta.glob<ImageMetadata>('/src/content/trips/**/*.jpg', {
  eager: true,
  import: 'default',
});

// Nur Bilder dieses Beitrags behalten
const imagesGlob = Object.fromEntries(
  Object.entries(allImages).filter(([file]) => file.includes(`/${id}/`))
) as Record<string, ImageMetadata>;
---

<html lang="de">
  <head>
    <BaseHead title={title} description={description} />
  </head>

  <body>
    <Header />

    <main>
      <article>
        <div class="hero-image">
          {
            heroImage && (
              <Image width={1020} height={510} src={heroImage} alt={heroImageAlt || title} />
            )
          }
        </div>

        <hr />
        <div class="prose">
          <div class="title">
            <h1>{title}</h1>

            <hr />

            <div class="icon-text__container">
              <div class="icon__wrapper">{CategoryIcon && <CategoryIcon />}</div>
            </div>
            <div class="date icon-text__container">
              <div class="icon__wrapper"><Date /></div>
              <FormattedDate date={pubDate} />
            </div>

            <div class="icon-text__container">
              <div class="icon__wrapper"><Distance /></div>
              {distance}
            </div>
            <div class="icon-text__container">
              <div class="icon__wrapper"><Start /></div>
              {start}
            </div>
            <div class="icon-text__container">
              <div class="icon__wrapper"><End /></div>
              {end}
            </div>
          </div>

          <hr />

          <div class="icon__wrapper"><Gpx /></div> &nbsp;
          <a href={gpx} target="_blank" download rel="noopener noreferrer">GPX-Datei</a>

          <slot />

          <hr />

          {
            images && images.length > 0 && (
              <>
                <hr />
                <Images imagesGlob={imagesGlob} imagesMeta={images} />
              </>
            )
          }
        </div>
      </article>

      <Footer />
    </main>
  </body>
</html>
